{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "marker",
  "version": "1.1.1",
  "identifier": "com.lwlee2608.marker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "marker",
        "width": 1100,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https: data: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:1421"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "role": "Viewer"
      }
    ]
  },
  "plugins": {
    "cli": {
      "description": "marker — a minimal Markdown viewer",
      "args": [
        {
          "name": "source",
          "index": 1,
          "takesValue": true,
          "description": "Path to a Markdown file to open"
        }
      ]
    }
  }
}
